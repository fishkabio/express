{
  "name": "@fishka/express",
  "version": "0.0.1",
  "description": "Express.js extension with built-in OpenAPI 3.0 documentation, validation, and type safety",
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js",
      "types": "./dist/index.d.ts"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://gitea.com/fishka/express.git"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "clean": "rm -rf dist",
    "format": "prettier --write \"./**/*.{ts,js,md,json}\"",
    "lint": "eslint .",
    "webpack": "webpack",
    "test": "jest",
    "release": "npm run lint && npm run test && npm run clean && npm run webpack && npm publish"
  },
  "keywords": [
    "express",
    "expressjs",
    "openapi",
    "typescript",
    "rest-api",
    "rest"
  ],
  "license": "MIT",
  "dependencies": {
    "@fishka/assertions": "^1.0.0",
    "openapi-types": "^12.1.3"
  },
  "peerDependencies": {
    "express": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": false
    }
  },
  "devDependencies": {
    "express": "^5.2.1",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.19.27",
    "@typescript-eslint/eslint-plugin": "^8.51.0",
    "@typescript-eslint/parser": "^8.51.0",
    "eslint": "^9.39.2",
    "eslint-plugin-unused-imports": "^4.3.0",
    "jest": "^30.2.0",
    "prettier": "^3.7.4",
    "prettier-plugin-organize-imports": "^4.3.0",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.2",
    "typescript": "^5.9.3",
    "webpack": "^5.99.7",
    "webpack-cli": "^5.1.4"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  }
}
